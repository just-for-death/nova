# Nova File Manager — Environment Variables
# Copy this to .env and edit as needed

# ── Main app port (host side) ────────────────────────────────────
HOST_PORT=9898

# ── Monitor sidecar port ─────────────────────────────────────────
MONITOR_PORT=9091

# ── Log verbosity: debug | info | warn | error ───────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty    # pretty (colored, human-readable) | json (machine-parseable)

# ── Parallel copy workers (increase for fast NVMe storage) ───────
COPY_WORKERS=4

# ── Health monitor settings ──────────────────────────────────────
CHECK_INTERVAL_SEC=30
FAIL_THRESHOLD=3

# ── Gotify push notifications (optional) ─────────────────────────
# Notifies on: job start, done, error, CANCELLED, and AI operations
# GOTIFY_URL=http://192.168.1.10:3030
# GOTIFY_TOKEN=your-gotify-app-token
GOTIFY_URL=
GOTIFY_TOKEN=

# ── Ollama AI (optional) ─────────────────────────────────────────
# host-gateway resolves to the Docker host IP automatically.
# If Ollama is on a different machine, use its IP/hostname.
OLLAMA_URL=http://host-gateway:11434

# Recommended models — small and fast:
#   llama3.2:1b      → fast text ops (summarize, rename, tag)
#   moondream:latest → image description
#   nomic-embed-text → semantic search (tiny, 274MB)
OLLAMA_TEXT_MODEL=llama3.2:1b
OLLAMA_VISION_MODEL=moondream:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ── Copy stream buffer per worker (bytes) ────────────────────────
# Higher values = faster on NVMe; lower = less RAM usage.
# Default: 2097152 (2 MB). Try 4194304 (4 MB) on fast disks.
COPY_HWM=2097152

# ── Ollama AI rate limiting ───────────────────────────────────────
# Caps AI requests per IP per window to prevent hammering Ollama.
# Default: 30 requests per 60 s.
OLLAMA_RATE_LIMIT=30
OLLAMA_RATE_WINDOW=60000
