{
  "name": "Nova File Manager",
  "short_name": "Nova",
  "description": "A fast, modern self-hosted file manager for Docker",
  "start_url": "/",
  "scope": "/",
  "id": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#1a1916",
  "theme_color": "#c4663a",
  "icons": [
    { "src": "/icon-120.png", "sizes": "120x120", "type": "image/png", "purpose": "any" },
    { "src": "/icon-152.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/icon-167.png", "sizes": "167x167", "type": "image/png", "purpose": "any" },
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "/favicon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" }
  ],
  "screenshots": [
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "form_factor": "narrow", "label": "Nova File Manager" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "form_factor": "wide", "label": "Nova File Manager" }
  ],
  "shortcuts": [
    { "name": "Root", "short_name": "Root", "description": "Browse root directory", "url": "/?path=/", "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }] },
    { "name": "Home", "short_name": "Home", "description": "Browse home directory", "url": "/?path=/home", "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }] }
  ],
  "share_target": {
    "action": "/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": { "files": [{ "name": "file", "accept": ["*/*"] }] }
  },
  "handle_links": "preferred",
  "launch_handler": { "client_mode": "focus-existing" },
  "categories": ["utilities", "productivity"],
  "lang": "en",
  "dir": "ltr",
  "prefer_related_applications": false
}
